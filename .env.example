# Copy this file to .env and fill in your values.
# The app runs in deterministic mode if ANTHROPIC_API_KEY is not set.

# Anthropic API key — enables AI agents (ERP Scanner, Follow-up Delivery)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: WhatsApp Business API (reserved for future MCP integration)
# WHATSAPP_API_KEY=...
# WHATSAPP_PHONE_NUMBER_ID=...

# Verbose agent logging — prints every prompt, response, token count,
# and tool call to the terminal. Useful during development.
# VERBOSE=true

# Optional: app server settings
# APP_HOST=0.0.0.0
# APP_PORT=7860
# APP_SHARE=false
